%%%Visualización y limpieza de datos%%%%


import pandas as pd
ri = pd.read_csv('police.csv')
print(ri.head())
print(ri.isnull().sum())
%Elimino columnas
print(ri.shape)
ri.drop(['county_name', 'state'], axis='columns', inplace=True)
print(ri.shape)
%Elimino filas
print(ri.isnull().sum())
ri.dropna(subset=['driver_gender'], inplace=True)
print(ri.isnull().sum())
print(ri.shape)


%%% Cambio de tipo de datos
display(ri.info())
print(ri.is_arrested.dtype) #Visualizo el tipo de datos de la columna

ri['is_arrested'] = ri.is_arrested.astype(bool)
print(ri.is_arrested.dtype)

%Tratamiento de las columnas "stop_date" y "stop_time" para unificarlas en una única columna
# Concateno las columnas
combined = ri.stop_date.str.cat(ri.stop_time,sep=' ')

# Convierno la nueva columna a formato fecha y hora y la llamo "stop_datetime"
ri['stop_datetime'] = pd.to_datetime(combined)
# Re-examino el df para observar que esté bien
print(ri.info())
#Defino como indice la nueva columna
ri.set_index('stop_datetime', inplace=True)




%%%%%%%Exploracion de relación entre género e infracciones
%Cuento la cantidad de los distintos incidentes ocurridos y calculo su proporcion
print(ri['violation'].value_counts())
print(ri['violation'].value_counts(normalize=True))

%%%Genero dos datasets. Uno de hombres y otro de mujeres y calculo las proporciones de infracciones.

female = ri[ri.driver_gender=='F']
male = ri[ri.driver_gender=='M']

print(female['violation'].value_counts(normalize=True))
print(male['violation'].value_counts(normalize=True))


%%%Calculo proporciones de nuevos df de mujeres y hombres cuya infraccion fue exceso de velocidad

female_and_speeding = ri[(ri.driver_gender=='F') & (ri.violation=='Speeding')]
male_and_speeding = ri[(ri.driver_gender=='M') & (ri.violation=='Speeding')]

print(female_and_speeding.stop_outcome.value_counts(normalize=True))
print(male_and_speeding.stop_outcome.value_counts(normalize=True))

#Calculo el promedio de registros por género por violacion
print(ri.groupby(['driver_gender','violation']).search_conducted.mean())


%Veo los tipos de delitos y hago una columna con los que incluyen "Protective Frisk"
print(ri.search_type.value_counts())
ri['frisk'] = ri.search_type.str.contains('Protective Frisk', na=False)
print(ri.frisk.dtype)
print(ri.frisk.sum())

# Create a DataFrame of stops in which a search was conducted
searched = ri[ri.search_conducted == True]
# Calculo el porcentaje de cacheos totales
print(searched.frisk.mean())
# Calculo los cacheos por género
print(searched.groupby('driver_gender').frisk.mean())


